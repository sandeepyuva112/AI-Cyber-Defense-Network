<Window
    x:Class="AI.CyberDefense.Desktop.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:AI.CyberDefense.Desktop.Models"
    Title="AI Cyber Defense Network"
    Width="1280"
    Height="820"
    MinWidth="1024"
    MinHeight="680"
    Background="{StaticResource AppBackgroundBrush}"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaToDecorationsHint="False">

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="FontFamily" Value="Inter" />
      <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <Style Selector="Button.sidebar-button">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="Margin" Value="0,3" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="CornerRadius" Value="7" />
    </Style>

    <Style Selector="Button.sidebar-button:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
    </Style>

    <Style Selector="Border.metric-card">
      <Setter Property="Background" Value="{StaticResource PanelElevatedBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="18" />
      <Setter Property="MinHeight" Value="132" />
    </Style>

    <Style Selector="Border.section-panel">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushMuted}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="20" />
    </Style>

    <Style Selector="Border.status-pill">
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="9,4" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="268,*">
    <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" BorderBrush="{StaticResource BorderBrushMuted}" BorderThickness="0,0,1,0">
      <Grid RowDefinitions="Auto,*,Auto" Margin="22">
        <StackPanel Spacing="8">
          <Border Width="48" Height="48" CornerRadius="8" Background="{StaticResource AccentSoftBrush}" HorizontalAlignment="Left">
            <TextBlock Text="AI" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource AccentBrush}" />
          </Border>
          <TextBlock Text="AI Cyber Defense Network" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" />
          <TextBlock Text="Analyst Console" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
        </StackPanel>

        <ListBox
            Grid.Row="1"
            Margin="0,34,0,0"
            Background="Transparent"
            BorderThickness="0"
            ItemsSource="{Binding NavigationItems}"
            SelectedItem="{Binding SelectedNavigationItem}">
          <ListBox.ItemTemplate>
            <DataTemplate DataType="models:NavigationItem">
              <Button Classes="sidebar-button">
                <Grid ColumnDefinitions="30,*">
                  <TextBlock Text="{Binding Icon}" FontSize="12" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="14" VerticalAlignment="Center" />
                </Grid>
              </Button>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushMuted}" BorderThickness="1" CornerRadius="8" Padding="14">
          <StackPanel Spacing="8">
            <TextBlock Text="Backend Status" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Ellipse Width="9" Height="9" Fill="{StaticResource LowBrush}" VerticalAlignment="Center" />
              <TextBlock Text="Ready for API connection" FontSize="13" />
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="30,24,30,30">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="6">
          <TextBlock Text="{Binding CurrentViewTitle}" FontSize="34" FontWeight="Bold" />
          <TextBlock Text="{Binding CurrentViewSubtitle}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <Button Padding="14,10" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushMuted}" CornerRadius="7">
            <TextBlock Text="Refresh" />
          </Button>
          <Button Padding="14,10" Background="{StaticResource AccentBrush}" BorderBrush="{StaticResource AccentBrush}" CornerRadius="7">
            <TextBlock Text="Upload Logs" Foreground="#04101D" FontWeight="SemiBold" />
          </Button>
        </StackPanel>
      </Grid>

      <Grid Grid.Row="1" ColumnDefinitions="*,22,330" Margin="0,28,0,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="22">
            <ItemsControl ItemsSource="{Binding Metrics}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <UniformGrid Columns="3" Rows="2" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate DataType="models:DashboardMetric">
                  <Border Classes="metric-card" Margin="0,0,14,14">
                    <Grid RowDefinitions="Auto,*,Auto">
                      <TextBlock Text="{Binding Title}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                      <TextBlock Grid.Row="1" Text="{Binding Value}" FontSize="36" FontWeight="Bold" Margin="0,12,0,6" />
                      <TextBlock Grid.Row="2" Text="{Binding Trend}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Classes="section-panel">
              <Grid RowDefinitions="Auto,*">
                <Grid ColumnDefinitions="*,Auto">
                  <StackPanel>
                    <TextBlock Text="Recent Alerts" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="AI-enriched detections awaiting analyst review" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />
                  </StackPanel>
                  <Border Grid.Column="1" Classes="status-pill" Background="{StaticResource AccentSoftBrush}">
                    <TextBlock Text="Live Feed" FontSize="12" Foreground="{StaticResource AccentBrush}" />
                  </Border>
                </Grid>

                <ItemsControl Grid.Row="1" Margin="0,18,0,0" ItemsSource="{Binding RecentAlerts}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:AlertItem">
                      <Border BorderBrush="{StaticResource BorderBrushMuted}" BorderThickness="0,1,0,0" Padding="0,14">
                        <Grid ColumnDefinitions="64,16,120,16,*,16,90">
                          <TextBlock Text="{Binding Time}" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" />
                          <Border Grid.Column="2" Classes="status-pill" Background="{StaticResource AccentSoftBrush}" HorizontalAlignment="Left">
                            <TextBlock Text="{Binding Severity}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                          </Border>
                          <StackPanel Grid.Column="4" Spacing="4">
                            <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Asset}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                            <TextBlock Text="{Binding FrameworkMapping}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                          </StackPanel>
                          <TextBlock Grid.Column="6" Text="{Binding Confidence, StringFormat={}{0}%}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Column="2" Spacing="18">
          <Border Classes="section-panel">
            <StackPanel Spacing="14">
              <TextBlock Text="Analysis Queue" FontSize="20" FontWeight="SemiBold" />
              <TextBlock Text="Next backend step will connect these UI states to FastAPI." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />

              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Parser" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock Grid.Column="1" Text="Idle" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="AI Analyzer" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock Grid.Column="1" Text="Ready" />
              </Grid>
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="Report Builder" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock Grid.Column="1" Text="Pending" />
              </Grid>
            </StackPanel>
          </Border>

          <Border Classes="section-panel">
            <StackPanel Spacing="14">
              <TextBlock Text="Framework Coverage" FontSize="20" FontWeight="SemiBold" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="MITRE ATT&amp;CK" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock Grid.Column="1" Text="4 techniques" />
              </Grid>
              <ProgressBar Minimum="0" Maximum="100" Value="68" Height="8" Foreground="{StaticResource AccentBrush}" Background="{StaticResource AccentSoftBrush}" />
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="NIST CSF" Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock Grid.Column="1" Text="Detect, Respond" />
              </Grid>
              <ProgressBar Minimum="0" Maximum="100" Value="54" Height="8" Foreground="{StaticResource LowBrush}" Background="{StaticResource AccentSoftBrush}" />
            </StackPanel>
          </Border>

          <Border Classes="section-panel">
            <StackPanel Spacing="10">
              <TextBlock Text="Supported Logs" FontSize="20" FontWeight="SemiBold" />
              <TextBlock Text="EVTX, auth.log, syslog, Apache, Nginx, JSON, and plain text." FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Window>
